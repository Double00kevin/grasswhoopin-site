---
import '../styles/global.css';

const cookie = Astro.cookies.get('gw_admin');
if (cookie?.value === 'authorized') {
  return Astro.redirect('/admin');
}

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const password = form.get('password')?.toString() ?? '';
  const adminPassword = Astro.locals.runtime.env.ADMIN_PASSWORD;

  if (password && password === adminPassword) {
    Astro.cookies.set('gw_admin', 'authorized', {
      httpOnly: true,
      secure: true,
      sameSite: 'strict',
      path: '/',
      maxAge: 60 * 60 * 24 * 7,
    });
    return Astro.redirect('/admin');
  } else {
    error = "Wrong password, recruit. Hit the road or try again.";
  }
}
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Grasswhoopin' HQ — Identify Yourself</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      body { font-family: 'Barlow', sans-serif; }
      h1   { font-family: 'Barlow Condensed', sans-serif; }
      .btn { font-family: 'Barlow Condensed', sans-serif; }
    </style>
  </head>
  <body class="bg-army min-h-screen flex items-center justify-center">
    <div class="w-full max-w-sm mx-auto px-6">

      <div class="text-center mb-8">
        <h1 class="text-4xl font-black text-deere tracking-widest uppercase">
          GRASSWHOOPIN' HQ
        </h1>
        <p class="text-screaming text-xs mt-2 tracking-[0.2em] uppercase">Authorized Personnel Only</p>
      </div>

      {error && (
        <div class="bg-rust/20 border border-rust text-rust text-sm p-3 rounded mb-4 text-center">
          {error}
        </div>
      )}

      <div class="bg-olive border border-camo rounded-lg p-6 mb-4">
        <a
          href="/auth/login"
          class="btn flex items-center justify-center gap-3 w-full bg-white text-army font-black py-2 px-4 rounded tracking-widest uppercase text-sm hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-5 h-5 shrink-0">
            <path fill="#4285F4" d="M46.5 24.5c0-1.6-.1-3.1-.4-4.5H24v8.5h12.7c-.6 3-2.3 5.5-4.8 7.2v6h7.8c4.5-4.2 7.1-10.3 7.1-17.2z"/>
            <path fill="#34A853" d="M24 48c6.5 0 11.9-2.1 15.9-5.8l-7.8-6c-2.1 1.4-4.9 2.3-8.1 2.3-6.2 0-11.5-4.2-13.4-9.9H2.6v6.2C6.5 42.7 14.7 48 24 48z"/>
            <path fill="#FBBC05" d="M10.6 28.6c-.5-1.4-.8-2.9-.8-4.6s.3-3.2.8-4.6v-6.2H2.6C1 16.4 0 20.1 0 24s1 7.6 2.6 10.8l8-6.2z"/>
            <path fill="#EA4335" d="M24 9.5c3.5 0 6.6 1.2 9.1 3.6l6.8-6.8C35.9 2.4 30.5 0 24 0 14.7 0 6.5 5.3 2.6 13.2l8 6.2C12.5 13.7 17.8 9.5 24 9.5z"/>
          </svg>
          Sign in with Google
        </a>
      </div>

      <div class="flex items-center gap-3 mb-4">
        <div class="flex-1 border-t border-camo"></div>
        <span class="text-gray-500 text-xs tracking-widest uppercase">or</span>
        <div class="flex-1 border-t border-camo"></div>
      </div>

      <form method="POST" class="bg-olive border border-camo rounded-lg p-6 space-y-4">
        <div>
          <label class="block text-gray-400 text-xs tracking-widest uppercase mb-1" for="password">
            Password
          </label>
          <input
            type="password"
            name="password"
            id="password"
            required
            autofocus
            class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
          />
        </div>
        <button
          type="submit"
          class="btn w-full bg-deere text-army font-black py-2 px-4 rounded tracking-widest uppercase text-sm hover:opacity-90 transition-opacity"
        >
          ENTER THE COMPOUND
        </button>
      </form>

    </div>
  </body>
</html>

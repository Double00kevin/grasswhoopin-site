---
import '../styles/global.css';

const cookie = Astro.cookies.get('gw_admin');
if (cookie?.value !== 'authorized') {
  return Astro.redirect('/auth/login');
}

const db = Astro.locals.runtime.env.grasswhoopin_db;

interface CustomerRow {
  id: number;
  name: string;
  address: string;
  phone: string | null;
  frequency: string;
  quoted_price: number | null;
  notes: string | null;
  created_at: string;
  last_cut: string | null;
  last_price: number | null;
  total_cuts: number;
}

const { results: customers } = await db
  .prepare(`
    SELECT
      c.*,
      MAX(cu.cut_date) AS last_cut,
      COUNT(cu.id) AS total_cuts,
      (SELECT price FROM cuts WHERE customer_id = c.id ORDER BY cut_date DESC, id DESC LIMIT 1) AS last_price
    FROM customers c
    LEFT JOIN cuts cu ON cu.customer_id = c.id
    WHERE c.active = 1
    GROUP BY c.id
    ORDER BY c.name
  `)
  .all<CustomerRow>();

interface DischargedRow {
  id: number;
  name: string;
  address: string;
  frequency: string;
}

const [monthStatsRes, allTimeStatsRes, monthCutsRes] = await db.batch([
  db.prepare(`SELECT COALESCE(SUM(price), 0) as total FROM cuts WHERE strftime('%Y-%m', cut_date) = strftime('%Y-%m', 'now')`),
  db.prepare(`SELECT COALESCE(SUM(price), 0) as total FROM cuts`),
  db.prepare(`SELECT COUNT(*) as count FROM cuts WHERE strftime('%Y-%m', cut_date) = strftime('%Y-%m', 'now')`),
]);
const revenueMonth = (monthStatsRes.results[0]  as any).total as number;
const revenueAll   = (allTimeStatsRes.results[0] as any).total as number;
const cutsMonth    = (monthCutsRes.results[0]    as any).count as number;

const { results: discharged } = await db
  .prepare('SELECT id, name, address, frequency FROM customers WHERE active = 0 ORDER BY name')
  .all<DischargedRow>();

const url = new URL(Astro.request.url);
const justAdded  = url.searchParams.get('added');
const justWhooped = url.searchParams.get('whooped');
const hasError   = url.searchParams.get('error');
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Grasswhoopin' Command Center</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;600&display=swap" rel="stylesheet" />
    <style>
      body, input, select, button { font-family: 'Barlow', sans-serif; }
      h1, h2, .condensed { font-family: 'Barlow Condensed', sans-serif; }
    </style>
  </head>
  <body class="bg-army min-h-screen text-gray-100">

    <!-- Header -->
    <header class="bg-olive border-b border-camo px-6 py-4 flex items-center justify-between sticky top-0 z-10">
      <h1 class="text-2xl font-black text-deere tracking-widest uppercase">
        COMMAND CENTER
      </h1>
      <a
        href="/admin/logout"
        class="text-xs text-gray-400 border border-camo rounded px-3 py-1 hover:border-rust hover:text-rust transition-colors tracking-widest uppercase"
      >
        FALL OUT
      </a>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8 space-y-10">

      <!-- Flash banners -->
      {justAdded && (
        <div class="bg-screaming/10 border border-screaming text-screaming text-sm p-3 rounded text-center tracking-wide">
          RECRUIT ENLISTED. WELCOME TO HELL.
        </div>
      )}
      {justWhooped && (
        <div class="bg-deere/10 border border-deere text-deere text-sm p-3 rounded text-center tracking-wide">
          YARD HAS BEEN WHOOPED. OUTSTANDING.
        </div>
      )}
      {hasError && (
        <div class="bg-rust/20 border border-rust text-rust text-sm p-3 rounded text-center tracking-wide">
          SOMETHING WENT WRONG. CHECK THE LOGS, SOLDIER.
        </div>
      )}

      <!-- Stats Panel -->
      <section class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <div class="bg-olive border border-camo rounded-lg p-4 text-center">
          <div class="condensed text-2xl font-black text-screaming">{customers.length}</div>
          <div class="text-xs text-gray-500 tracking-widest uppercase mt-1">Active Recruits</div>
        </div>
        <div class="bg-olive border border-camo rounded-lg p-4 text-center">
          <div class="condensed text-2xl font-black text-deere">{cutsMonth}</div>
          <div class="text-xs text-gray-500 tracking-widest uppercase mt-1">Cuts This Month</div>
        </div>
        <div class="bg-olive border border-camo rounded-lg p-4 text-center">
          <div class="condensed text-2xl font-black text-deere">${revenueMonth.toFixed(2)}</div>
          <div class="text-xs text-gray-500 tracking-widest uppercase mt-1">Revenue This Month</div>
        </div>
        <div class="bg-olive border border-camo rounded-lg p-4 text-center">
          <div class="condensed text-2xl font-black text-screaming">${revenueAll.toFixed(2)}</div>
          <div class="text-xs text-gray-500 tracking-widest uppercase mt-1">Revenue All-Time</div>
        </div>
      </section>

      <!-- Enlist New Recruit -->
      <section>
        <h2 class="text-xl font-black text-deere tracking-widest uppercase mb-4">
          ENLIST NEW RECRUIT
        </h2>
        <form
          method="POST"
          action="/api/customers"
          class="bg-olive border border-camo rounded-lg p-6 grid grid-cols-1 sm:grid-cols-2 gap-4"
        >
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="name">Name *</label>
            <input
              type="text" name="name" id="name" required
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="phone">Phone</label>
            <input
              type="tel" name="phone" id="phone"
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="address">Address *</label>
            <input
              type="text" name="address" id="address" required
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="frequency">Frequency</label>
            <select
              name="frequency" id="frequency"
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            >
              <option value="weekly">Weekly</option>
              <option value="bi-weekly">Bi-Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="one-time">One-Time</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="quoted_price">Quoted Price</label>
            <div class="flex items-center bg-army border border-camo rounded overflow-hidden focus-within:border-deere transition-colors">
              <span class="px-2 text-gray-500 select-none text-sm">$</span>
              <input
                type="number" name="quoted_price" id="quoted_price" min="0" step="0.01" placeholder="0.00"
                class="w-full bg-transparent py-2 pr-3 text-white focus:outline-none text-sm"
              />
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="notes">Notes</label>
            <input
              type="text" name="notes" id="notes"
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div class="sm:col-span-2">
            <button
              type="submit"
              class="condensed bg-deere text-army font-black py-2 px-6 rounded tracking-widest uppercase text-sm hover:opacity-90 transition-opacity"
            >
              ENLIST RECRUIT
            </button>
          </div>
        </form>
      </section>

      <!-- Recruits Roster -->
      <section>
        <h2 class="text-xl font-black text-deere tracking-widest uppercase mb-4">
          RECRUITS ROSTER
          <span class="text-gray-500 font-normal text-base normal-case tracking-normal ml-2">
            ({customers.length})
          </span>
        </h2>

        {customers.length === 0 ? (
          <p class="text-gray-500 italic text-sm">No recruits on the rolls yet. Enlist your first one above.</p>
        ) : (
          <div class="space-y-3">
            {customers.map((c) => (
              <div id={`recruit-${c.id}`} class="bg-olive border border-camo rounded-lg p-4 flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span class="condensed recruit-name text-lg font-bold text-white tracking-wide">{c.name}</span>
                    <span class="recruit-freq text-xs text-gray-500 border border-camo rounded px-2 py-0.5 uppercase tracking-wider">
                      {c.frequency}
                    </span>
                    {c.quoted_price != null && (
                      <span class="recruit-quoted text-xs text-deere border border-deere/40 rounded px-2 py-0.5 tracking-wider">
                        ${c.quoted_price.toFixed(2)}/cut
                      </span>
                    )}
                  </div>
                  <div class="recruit-address text-sm text-gray-400">{c.address}</div>
                  {c.phone && <div class="recruit-phone text-sm text-gray-400">{c.phone}</div>}
                  {c.notes && <div class="recruit-notes text-xs text-gray-500 mt-0.5 italic">{c.notes}</div>}
                  <div class="text-xs mt-1.5">
                    {c.last_cut
                      ? <span class="text-screaming">
                          Last whooped: {c.last_cut}
                          {c.last_price != null && <> &mdash; <span class="text-deere">${c.last_price.toFixed(2)}</span></>}
                          {' '}&mdash; {c.total_cuts} total
                        </span>
                      : <span class="text-rust font-bold tracking-wide uppercase">NEVER WHOOPED</span>
                    }
                  </div>
                </div>
                <div class="shrink-0 flex flex-col gap-2 items-stretch">
                  <form method="POST" action="/api/cuts" class="flex flex-col gap-1.5">
                    <input type="hidden" name="customer_id" value={c.id} />
                    <div class="flex items-center bg-army border border-camo rounded overflow-hidden text-sm focus-within:border-deere transition-colors">
                      <span class="px-2 text-gray-500 select-none">$</span>
                      <input
                        type="number" name="price" min="0" step="0.01" placeholder="0.00"
                        class="w-full bg-transparent py-1.5 pr-2 text-white focus:outline-none"
                      />
                    </div>
                    <button
                      type="submit"
                      class="condensed w-full bg-screaming text-army font-black py-2 px-5 rounded tracking-widest uppercase text-sm hover:opacity-90 transition-opacity whitespace-nowrap"
                    >
                      GRASSWHOOPED
                    </button>
                  </form>
                  <button
                    type="button"
                    class="condensed edit-btn text-xs text-deere border border-camo rounded px-3 py-1.5 hover:border-deere transition-colors tracking-widest uppercase"
                    data-id={String(c.id)}
                    data-name={c.name}
                    data-address={c.address}
                    data-phone={c.phone ?? ''}
                    data-frequency={c.frequency}
                    data-quoted_price={c.quoted_price != null ? String(c.quoted_price) : ''}
                    data-notes={c.notes ?? ''}
                  >
                    EDIT
                  </button>
                  <button
                    type="button"
                    class="condensed discharge-btn text-xs text-gray-500 border border-camo rounded px-3 py-1.5 hover:border-rust hover:text-rust transition-colors tracking-widest uppercase"
                    data-id={String(c.id)}
                    data-name={c.name}
                  >
                    DISCHARGE
                  </button>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>

      <!-- Discharged Roster -->
      {discharged.length > 0 && (
        <section>
          <details>
            <summary class="cursor-pointer list-none flex flex-wrap items-center gap-2 mb-4">
              <h2 class="condensed text-xl font-black text-rust tracking-widest uppercase">
                DISCHARGED
              </h2>
              <span class="text-gray-500 font-normal text-base normal-case tracking-normal">
                ({discharged.length})
              </span>
              <span class="text-gray-500 text-xs tracking-widest uppercase ml-auto">▼ EXPAND</span>
            </summary>
            <div class="space-y-3">
              {discharged.map((c) => (
                <div id={`discharged-${c.id}`} class="bg-olive border border-camo/50 rounded-lg p-4 flex flex-col sm:flex-row sm:items-center gap-4 opacity-60">
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-1">
                      <span class="condensed text-lg font-bold text-gray-400 tracking-wide">{c.name}</span>
                      <span class="text-xs text-gray-600 border border-camo/50 rounded px-2 py-0.5 uppercase tracking-wider">{c.frequency}</span>
                    </div>
                    <div class="text-sm text-gray-600">{c.address}</div>
                  </div>
                  <button
                    type="button"
                    class="condensed reinstate-btn shrink-0 text-xs text-screaming border border-screaming/40 rounded px-3 py-1.5 hover:border-screaming transition-colors tracking-widest uppercase"
                    data-id={String(c.id)}
                    data-name={c.name}
                  >
                    REINSTATE
                  </button>
                </div>
              ))}
            </div>
          </details>
        </section>
      )}

    </main>

    <!-- Edit Recruit Modal -->
    <div
      id="edit-modal"
      class="fixed inset-0 z-50 hidden items-center justify-center p-4"
      role="dialog"
      aria-modal="true"
      aria-labelledby="edit-modal-title"
    >
      <!-- Backdrop -->
      <div id="edit-backdrop" class="absolute inset-0 bg-black/70"></div>

      <!-- Panel -->
      <div class="relative w-full max-w-lg bg-olive border border-camo rounded-lg p-6 shadow-xl">
        <h2 id="edit-modal-title" class="condensed text-xl font-black text-deere tracking-widest uppercase mb-5">
          AMEND RECRUIT
        </h2>

        <form id="edit-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input type="hidden" id="edit-id" name="id" />

          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="edit-name">Name *</label>
            <input
              type="text" id="edit-name" name="name" required
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="edit-phone">Phone</label>
            <input
              type="tel" id="edit-phone" name="phone"
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div class="sm:col-span-2">
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="edit-address">Address *</label>
            <input
              type="text" id="edit-address" name="address" required
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="edit-frequency">Frequency</label>
            <select
              id="edit-frequency" name="frequency"
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            >
              <option value="weekly">Weekly</option>
              <option value="bi-weekly">Bi-Weekly</option>
              <option value="monthly">Monthly</option>
              <option value="one-time">One-Time</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="edit-quoted_price">Quoted Price</label>
            <div class="flex items-center bg-army border border-camo rounded overflow-hidden focus-within:border-deere transition-colors">
              <span class="px-2 text-gray-500 select-none text-sm">$</span>
              <input
                type="number" id="edit-quoted_price" name="quoted_price" min="0" step="0.01" placeholder="0.00"
                class="w-full bg-transparent py-2 pr-3 text-white focus:outline-none text-sm"
              />
            </div>
          </div>
          <div>
            <label class="block text-xs text-gray-400 tracking-widest uppercase mb-1" for="edit-notes">Notes</label>
            <input
              type="text" id="edit-notes" name="notes"
              class="w-full bg-army border border-camo rounded px-3 py-2 text-white focus:outline-none focus:border-deere text-sm"
            />
          </div>

          <div class="sm:col-span-2 flex flex-col sm:flex-row gap-3 pt-1">
            <button
              type="submit"
              class="condensed flex-1 bg-deere text-army font-black py-2 px-6 rounded tracking-widest uppercase text-sm hover:opacity-90 transition-opacity"
            >
              SAVE CHANGES
            </button>
            <button
              type="button"
              id="edit-cancel"
              class="condensed flex-1 text-gray-400 border border-camo rounded py-2 px-6 tracking-widest uppercase text-sm hover:border-gray-400 transition-colors"
            >
              STAND DOWN
            </button>
          </div>
        </form>

        <p id="edit-error" class="hidden text-rust text-xs mt-3 tracking-wide">Failed to save. Try again, soldier.</p>
      </div>
    </div>

    <script>
      // --- Reinstate ---
      document.querySelectorAll<HTMLButtonElement>('.reinstate-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const { id, name = 'this recruit' } = btn.dataset;
          if (!confirm(`Reinstate ${name} to active roster?`)) return;

          const res = await fetch(`/api/customers?id=${id}`, { method: 'PATCH' });
          if (res.ok) {
            document.getElementById(`discharged-${id}`)?.remove();
            window.location.reload();
          } else {
            alert('Failed to reinstate. Check the logs.');
          }
        });
      });

      // --- Discharge ---
      document.querySelectorAll<HTMLButtonElement>('.discharge-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const { id, name = 'this recruit' } = btn.dataset;
          if (!confirm(`DISCHARGE ${name.toUpperCase()} from the rolls?\n\nThis removes their full cut history. No take-backs.`)) return;

          const res = await fetch(`/api/customers?id=${id}`, { method: 'DELETE' });
          if (res.ok) {
            document.getElementById(`recruit-${id}`)?.remove();
          } else {
            alert('Failed to discharge recruit. Check the logs.');
          }
        });
      });

      // --- Edit modal ---
      const modal     = document.getElementById('edit-modal')!;
      const backdrop  = document.getElementById('edit-backdrop')!;
      const form      = document.getElementById('edit-form') as HTMLFormElement;
      const cancelBtn = document.getElementById('edit-cancel')!;
      const errMsg    = document.getElementById('edit-error')!;

      function openModal(btn: HTMLButtonElement) {
        const { id, name, address, phone, frequency, quoted_price, notes } = btn.dataset;
        (document.getElementById('edit-id')           as HTMLInputElement).value = id ?? '';
        (document.getElementById('edit-name')         as HTMLInputElement).value = name ?? '';
        (document.getElementById('edit-address')      as HTMLInputElement).value = address ?? '';
        (document.getElementById('edit-phone')        as HTMLInputElement).value = phone ?? '';
        (document.getElementById('edit-quoted_price') as HTMLInputElement).value = quoted_price ?? '';
        (document.getElementById('edit-notes')        as HTMLInputElement).value = notes ?? '';
        const sel = document.getElementById('edit-frequency') as HTMLSelectElement;
        sel.value = frequency ?? 'weekly';
        errMsg.classList.add('hidden');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        (document.getElementById('edit-name') as HTMLInputElement).focus();
      }

      function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }

      document.querySelectorAll<HTMLButtonElement>('.edit-btn').forEach((btn) => {
        btn.addEventListener('click', () => openModal(btn));
      });

      cancelBtn.addEventListener('click', closeModal);
      backdrop.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errMsg.classList.add('hidden');

        const id = (document.getElementById('edit-id') as HTMLInputElement).value;
        const data = new FormData(form);

        const res = await fetch(`/api/customers?id=${id}`, { method: 'PUT', body: data });

        if (!res.ok) {
          errMsg.classList.remove('hidden');
          return;
        }

        // Update the roster card in place without a full reload
        const card = document.getElementById(`recruit-${id}`);
        if (card) {
          const name         = data.get('name')?.toString() ?? '';
          const address      = data.get('address')?.toString() ?? '';
          const phone        = data.get('phone')?.toString() ?? '';
          const frequency    = data.get('frequency')?.toString() ?? '';
          const quotedRaw    = data.get('quoted_price')?.toString() ?? '';
          const quoted_price = quotedRaw ? parseFloat(quotedRaw) : null;
          const notes        = data.get('notes')?.toString() ?? '';

          card.querySelector<HTMLElement>('.recruit-name')!.textContent = name;
          card.querySelector<HTMLElement>('.recruit-address')!.textContent = address;

          const phoneEl = card.querySelector<HTMLElement>('.recruit-phone');
          if (phoneEl) phoneEl.textContent = phone || '';

          const notesEl = card.querySelector<HTMLElement>('.recruit-notes');
          if (notesEl) notesEl.textContent = notes || '';

          const freqEl = card.querySelector<HTMLElement>('.recruit-freq');
          if (freqEl) freqEl.textContent = frequency;

          const quotedEl = card.querySelector<HTMLElement>('.recruit-quoted');
          if (quoted_price != null) {
            const label = `$${quoted_price.toFixed(2)}/cut`;
            if (quotedEl) {
              quotedEl.textContent = label;
            } else {
              // Badge didn't exist before — insert it after the freq badge
              const freqBadge = card.querySelector('.recruit-freq');
              if (freqBadge) {
                const span = document.createElement('span');
                span.className = 'recruit-quoted text-xs text-deere border border-deere/40 rounded px-2 py-0.5 tracking-wider';
                span.textContent = label;
                freqBadge.insertAdjacentElement('afterend', span);
              }
            }
          } else if (quotedEl) {
            quotedEl.remove();
          }

          // Keep edit-btn data attrs in sync for subsequent edits
          const editBtn = card.querySelector<HTMLButtonElement>('.edit-btn');
          if (editBtn) {
            editBtn.dataset.name = name;
            editBtn.dataset.address = address;
            editBtn.dataset.phone = phone;
            editBtn.dataset.frequency = frequency;
            editBtn.dataset.quoted_price = quotedRaw;
            editBtn.dataset.notes = notes;
          }
          // Keep discharge-btn name in sync
          const dischargeBtn = card.querySelector<HTMLButtonElement>('.discharge-btn');
          if (dischargeBtn) dischargeBtn.dataset.name = name;
        }

        closeModal();
      });
    </script>

  </body>
</html>

---
---
<section class="min-h-screen bg-army flex flex-col items-center justify-center text-center px-6 py-16">

  <!-- Stick figure pushing reel mower SVG -->
  <svg
    viewBox="0 0 160 120"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    stroke="#ffde00"
    stroke-width="3"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="w-36 h-28 md:w-48 md:h-36 mb-8"
    aria-label="Determined person pushing a reel mower"
    role="img"
  >
    <!-- Head -->
    <circle cx="120" cy="18" r="12" />
    <!-- Furrowed brow — two short angled lines above eyes -->
    <line x1="112" y1="12" x2="117" y2="15" />
    <line x1="128" y1="12" x2="123" y2="15" />
    <!-- Body, leaning forward -->
    <line x1="120" y1="30" x2="100" y2="64" />
    <!-- Arm reaching forward to handle -->
    <line x1="110" y1="45" x2="72" y2="68" />
    <!-- Back leg -->
    <line x1="100" y1="64" x2="116" y2="94" />
    <!-- Front leg -->
    <line x1="100" y1="64" x2="84" y2="90" />
    <!-- Back foot -->
    <line x1="116" y1="94" x2="124" y2="94" />
    <!-- Front foot -->
    <line x1="84" y1="90" x2="76" y2="90" />
    <!-- Mower handle -->
    <line x1="72" y1="68" x2="50" y2="82" />
    <!-- Mower deck -->
    <rect x="10" y="78" width="48" height="12" rx="2" />
    <!-- Front wheel -->
    <circle cx="19" cy="92" r="6" />
    <!-- Back wheel -->
    <circle cx="49" cy="92" r="6" />
    <!-- Reel cylinder -->
    <circle cx="34" cy="84" r="7" />
    <!-- Reel blades (cross pattern) -->
    <line x1="34" y1="77" x2="34" y2="91" />
    <line x1="27" y1="84" x2="41" y2="84" />
    <line x1="29" y1="79" x2="39" y2="89" />
    <line x1="39" y1="79" x2="29" y2="89" />
  </svg>

  <h1 class="text-5xl sm:text-7xl md:text-9xl font-black mb-4 text-deere leading-none uppercase tracking-tight">
    Does Your Yard Need a <span class="text-screaming">Grasswhoopin'?</span>
  </h1>

  <p class="text-lg md:text-2xl mb-10 font-bold text-screaming tracking-wide">
    We'll handle it.
  </p>

  <a
    href="#contact"
    class="inline-block bg-transparent text-deere text-xl md:text-2xl px-10 py-5 font-black uppercase border-4 border-deere shadow-[6px_6px_0px_0px_rgba(255,222,0,0.4)] hover:bg-screaming hover:text-black hover:border-screaming hover:scale-105 transition-all"
  >
    Text Us Now
  </a>

</section>

---
---

<section class="hero min-h-screen flex items-center overflow-hidden relative">

  <!-- Gradient overlay: left lighter so mascot shows through, right darker for text readability -->
  <div class="overlay absolute inset-0" aria-hidden="true"></div>

  <!-- Content: centered on mobile, right half on desktop -->
  <div class="relative z-10 w-full flex justify-center md:justify-end">
    <div class="max-w-xl w-full px-6 py-20 md:py-0 md:pr-16 lg:pr-24 text-center md:text-left">

      <!-- Headline -->
      <div class="mb-6 leading-none">
        <div class="text-5xl sm:text-7xl md:text-8xl font-black uppercase tracking-tight text-deere">DOES YOUR YARD</div>
        <div class="text-5xl sm:text-7xl md:text-8xl font-black uppercase tracking-tight text-white">NEED A</div>
        <div class="text-6xl sm:text-8xl md:text-9xl font-black uppercase tracking-tight text-screaming">GRASSWHOOPIN'?</div>
      </div>

      <!-- Tagline -->
      <p class="text-xl md:text-2xl font-bold italic text-rust mb-10">We'll handle it.</p>

      <!-- CTA Button -->
      <a href="#contact" class="cta-btn inline-block text-deere border-4 border-deere px-10 py-5 text-xl md:text-2xl font-black uppercase tracking-wider">
        TEXT US NOW
      </a>

    </div>
  </div>

</section>

<style>
  .hero {
    background-image: url('/mascot.jpg');
    background-size: cover;
    background-position: center;
  }
  .overlay {
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.25) 0%,
      rgba(0, 0, 0, 0.20) 35%,
      rgba(0, 0, 0, 0.78) 58%,
      rgba(0, 0, 0, 0.88) 100%
    );
  }
  .cta-btn {
    box-shadow: 0 0 18px rgba(250, 204, 21, 0.35);
    transition: box-shadow 0.2s;
  }
  .cta-btn:hover {
    box-shadow: 0 0 36px rgba(250, 204, 21, 0.72);
    animation: shake 0.4s ease-in-out;
  }
</style>

---
---

<section class="hero min-h-screen relative overflow-hidden">
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-12 md:py-20">

    <!-- Two-column row: text left / image right on desktop; image top / text below on mobile -->
    <div class="top-row flex flex-col md:flex-row">

      <!-- Text stack: desktop order-1 (left), mobile order-2 (below image). z-index above image. -->
      <div class="text-col order-2 md:order-1 text-center md:text-left relative z-10">
        <div class="word font-black uppercase leading-none text-deere">DOES</div>
        <div class="word font-black uppercase leading-none text-deere">YOUR</div>
        <div class="word font-black uppercase leading-none text-deere">YARD</div>
        <div class="word font-black uppercase leading-none text-deere">NEED A</div>
      </div>

      <!-- Mascot image: desktop order-2 (right), mobile order-1 (top). z-index below text. -->
      <div class="mascot-col order-1 md:order-2">
        <img
          src="/mascot.png"
          alt="Grasswhoopin' mascot"
          class="mascot-img"
        />
      </div>

    </div>

    <!-- GRASSWHOOPIN'? — full width below both columns, no top spacing, image bleeds naturally -->
    <div class="grasswhoopin font-black uppercase leading-none text-center md:text-left">GRASSWHOOPIN'?</div>

    <!-- Tagline and CTA — centered -->
    <div class="text-center mt-10">
      <p class="text-xl md:text-2xl font-bold italic text-rust mb-10">We'll handle it.</p>
      <a href="#contact" class="cta-btn inline-block text-deere border-4 border-deere px-10 py-5 text-xl md:text-2xl font-black uppercase tracking-wider">
        TEXT US NOW
      </a>
    </div>

  </div>
</section>

<style>
  .hero {
    background: linear-gradient(to bottom, #0F2C23, #000000);
  }

  /* Stacked headline words */
  .word {
    font-size: clamp(3rem, 8vw, 7rem);
  }

  /* Mascot image — mobile: full width, centered, natural height */
  .mascot-col {
    width: 100%;
    display: flex;
    justify-content: center;
    /* no background, border, shadow, border-radius, or padding */
  }
  .mascot-img {
    width: 100%;
    max-width: 480px;
    height: auto;
    display: block;
  }

  /* Desktop: equal-height columns, image overlaps text by ~35px */
  @media (min-width: 768px) {
    .top-row {
      align-items: stretch;
      gap: 0;
    }
    .text-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .mascot-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: stretch;
      margin-left: -35px; /* pulls image left into text column space */
      position: relative;
      z-index: 1; /* below text-col z-index: 10 */
    }
    .mascot-img {
      width: 100%;
      max-width: unset;
      height: 100%;
      object-fit: cover;
      object-position: top center;
    }
  }

  /* GRASSWHOOPIN'? — gradient text, no top margin so image bleeds naturally into it */
  .grasswhoopin {
    font-size: clamp(2.5rem, 8.5vw, 8rem);
    background: linear-gradient(to right, #FACC15, #4ADE80);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    filter: drop-shadow(1px 1px 3px rgba(0, 0, 0, 0.8));
  }

  /* CTA button */
  .cta-btn {
    box-shadow: 0 0 18px rgba(250, 204, 21, 0.35);
    transition: box-shadow 0.2s;
  }
  .cta-btn:hover {
    box-shadow: 0 0 36px rgba(250, 204, 21, 0.72);
    animation: shake 0.4s ease-in-out;
  }
</style>

---
const testimonials = [
  {
    quote: "He showed up when he said he would. Didn't talk a lot. Yard looks good. That's really all I needed.",
    name: "Billy Ray",
    location: "Ardmore, TN"
  },
  {
    quote: "I was skeptical because the name is ridiculous. Yard's been perfect for three months. I'll give him that.",
    name: "Miss Darlene",
    location: "Athens, AL"
  },
  {
    quote: "He took care of my mama's yard while she was in the hospital. Didn't make a big deal about it. That says something.",
    name: "James Earl",
    location: "Elkmont, AL"
  },
  {
    quote: "Prices are fair. Shows up every week. My neighbor finally stopped giving me looks.",
    name: "Rhonda",
    location: "Taft, TN"
  }
];
---
<section class="py-20 bg-dirt border-y-8 border-camo">
  <div class="container mx-auto px-6">
    <h2 class="text-5xl md:text-7xl font-black mb-12 text-deere uppercase text-center italic">
      Neighbors Say
    </h2>
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      {testimonials.map(t => (
        <div class="bg-army p-8 border-4 border-camo shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
          <p class="text-lg md:text-xl font-bold italic text-gray-100 mb-6">"{t.quote}"</p>
          <p class="text-screaming font-black uppercase text-sm tracking-widest">
            {t.name} &mdash; {t.location}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

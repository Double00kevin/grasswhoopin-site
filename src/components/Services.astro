---
const services = [
  {
    name: "Weekly Mowing",
    desc: "Show up, whoop some grass, done. Same time every week, no reminders needed."
  },
  {
    name: "Edging & Trimming",
    desc: "The mower can't get everything. We can."
  },
  {
    name: "Weed Control",
    desc: "We know what's supposed to be there. Everything else goes."
  },
  {
    name: "Full Yard Overhaul",
    desc: "If it got away from you, we can get it back. No judgment."
  }
];
---
<section id="services" class="py-20 bg-dirt border-y-8 border-camo">
  <div class="container mx-auto px-6">
    <h2 class="text-5xl md:text-7xl font-black mb-12 text-deere uppercase text-center italic">
      What We Do
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(s => (
        <div class="bg-army p-8 border-4 border-camo shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
          <h3 class="text-2xl font-black text-screaming mb-4 uppercase">{s.name}</h3>
          <p class="text-lg font-bold italic text-gray-200">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

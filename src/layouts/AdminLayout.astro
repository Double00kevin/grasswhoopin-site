---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Grasswhoopin' Command Center</title>
    <meta name="robots" content="noindex, nofollow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=Barlow:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <style>
      body, input, select, button { font-family: 'Barlow', sans-serif; }
      h1, h2, .condensed { font-family: 'Barlow Condensed', sans-serif; }
    </style>
  </head>

  <body class="bg-army min-h-screen text-gray-100">

    <!-- Header -->
    <header class="bg-olive border-b border-camo px-6 py-4 flex items-center justify-between sticky top-0 z-10">
      <h1 class="text-2xl font-black text-deere tracking-widest uppercase">
        COMMAND CENTER
      </h1>

      <a
        href="/admin/logout"
        class="text-xs text-gray-400 border border-camo rounded px-3 py-1 hover:border-rust hover:text-rust transition-colors tracking-widest uppercase"
      >
        FALL OUT
      </a>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8 space-y-10">
      <slot />
    </main>

  </body>
</html>
